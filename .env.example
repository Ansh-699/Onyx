# ─── Network ────────────────────────────────────────────────────────────────
# "devnet" | "mainnet"
ONYX_NETWORK=devnet

# ─── TxLINE (TxODDS) data layer ───────────────────────────────────────────────
# Devnet API host (must match network; NEVER cross-activate devnet tx on mainnet host)
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_API_BASE_URL=https://txline-dev.txodds.com/api
TXLINE_JWT_URL=https://txline-dev.txodds.com/auth/guest/start

# Free World Cup tier: service level 1 (60s delay) or 12 (real-time, mainnet)
TXLINE_SERVICE_LEVEL_ID=1
TXLINE_DURATION_WEEKS=4

# Optional: paste a working API token to bypass the on-chain subscribe+activate flow
TXLINE_JWT=
TXLINE_API_TOKEN=

# ─── Solana ───────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
# Path to a funded devnet keypair JSON (for the on-chain subscribe step)
ANCHOR_WALLET=./_keys/devnet-wallet.json

# txoracle program (devnet). Re-verify before settlement CPI.
TXORACLE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
# Free-tier subscription mint is Token-2022 TxL (devnet)
TXL_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG

# ONYX settlement program (devnet). Matches declare_id! in programs/onyx/src/lib.rs
# and the committed programs/onyx/onyx-keypair.json.
ONYX_PROGRAM_ID=4LpMzq6wXYFMzxgbyMyN2ja4EQhPsYGHSCAvjwzA18MB

# ─── MagicBlock (verified live on devnet incl. TEE) ──────────────────────────
MAGICBLOCK_RPC_URL=https://rpc.magicblock.app/devnet
MAGICBLOCK_ROUTER_URL=https://devnet-router.magicblock.app/
