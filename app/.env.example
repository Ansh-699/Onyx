# Copy to .env.local (gitignored) and fill in.

# Client-exposed (NEXT_PUBLIC_*) — no secrets, program IDs are public.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_ONYX_PROGRAM_ID=4LpMzq6wXYFMzxgbyMyN2ja4EQhPsYGHSCAvjwzA18MB
NEXT_PUBLIC_TXORACLE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J

# Server-only (used by app/src/app/api/house-counter/route.ts — the demo
# liquidity-seeding route, see README "Being straight about what's real" —
# never sent to the browser). Point this at a funded devnet keypair; it also
# needs to be the mint authority of the test-USDC mint set up by
# services/ingestion/src/l0_loop_test.ts.
ANCHOR_WALLET=/path/to/your/devnet-keypair.json
SOLANA_RPC_URL=https://api.devnet.solana.com

# Server-only TxLINE credentials (never sent to the browser). Used by the
# LIVE settlement-proof pipeline (app/src/lib/txlineSettlementProof.ts +
# /api/settlement-proof) and by `bun run demo:amm` / `demo:amm-er`, which
# settle their markets with a live proof. Without these, live settlement
# honestly reports "not configured" — the bundled demo fixture still
# settles offline, and `bun run demo` (sealed) works fully.
TXLINE_JWT=
TXLINE_API_TOKEN=
# Optional overrides (defaults shown):
# TXLINE_API_ORIGIN=https://txline-dev.txodds.com
# TXLINE_API_BASE_URL=${TXLINE_API_ORIGIN}/api
